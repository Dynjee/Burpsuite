def queueRequests(target, wordlists):
    engine = RequestEngine(endpoint=target.endpoint,
                           concurrentConnections=5000,
                           requestsPerConnection=10000,
                           pipeline=False 
                           )
# engine settings. the concurrentConnections parameter is set to 5000 this will be bad if the web has rate-limit
# tweak if needed.
    for number in range(1000,10000):
        engine.queue(target.req, number)
# sends out requests with 1000-10000


